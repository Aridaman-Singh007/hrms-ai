POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hrms_ai

APP_NAME=HRMS AI Backend
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# LLM provider: gemini | bedrock
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=apac.amazon.nova-lite-v1:0

# OCR for scanned / image-only PDFs
# OCR_PROVIDER: auto | paddleocr | tesseract | bedrock | textract
# auto order: paddleocr -> tesseract -> bedrock (expensive) -> textract (optional/future)
OCR_ENABLED=true
OCR_PROVIDER=auto
